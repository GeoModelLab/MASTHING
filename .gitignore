*.vssscc
.builds

# Rider
.idea/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Coverage
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# macOS / Linux / Windows clutter
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Python environment (for optional analysis scripts)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# Editor config
*.swp
*.swo
*~

# Large input / output data (tracked outside git; see Zenodo data deposit)
# Uncomment and adapt as needed
# files/referenceData/*.csv
# files/weather/*.csv
# files/output/*.csv

# Sensitive config files (copy .example to local and keep local out of git)
*.local.json
secrets.json

# Optimizer run outputs
optimizerResults/
calibrationResults/
*.log
